<div class="quickbar" id="quickbar">
    <div class="qb-item">
        <span class="qb-flag">🇻🇳</span>
        <span>Hà Nội</span>
        <span class="qb-status status-moderate bg-moderate">Trung bình</span>
        <button class="qb-plus" onclick="event.stopPropagation()">＋</button>
    </div>
    <div class="qb-item">
        <span class="qb-flag">🇻🇳</span>
        <span>TP. Hồ Chí Minh</span>
        <span class="qb-status status-sensitive bg-sensitive">Kém</span>
        <button class="qb-plus" onclick="event.stopPropagation()">＋</button>
    </div>
    <div class="qb-item">
        <span class="qb-flag">🇻🇳</span>
        <span>Đà Nẵng</span>
        <span class="qb-status status-good bg-good">Tốt</span>
        <button class="qb-plus" onclick="event.stopPropagation()">＋</button>
    </div>
    <div class="qb-item">
        <span class="qb-flag">🇻🇳</span>
        <span>Cần Thơ</span>
        <span class="qb-status status-good bg-good">Tốt</span>
        <button class="qb-plus" onclick="event.stopPropagation()">＋</button>
    </div>
    <div class="qb-item">
        <span class="qb-flag">🇻🇳</span>
        <span>Hải Phòng</span>
        <span class="qb-status status-moderate bg-moderate">Trung bình</span>
        <button class="qb-plus" onclick="event.stopPropagation()">＋</button>
    </div>
    <div class="qb-nav-arrow">
        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" width="13" height="13">
            <polyline points="9 18 15 12 9 6" />
        </svg>
    </div>
</div>
