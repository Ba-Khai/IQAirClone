@* ===================================================
   _Header.cshtml — IQAir Navigation Header
   Giống style: Logo trái, nav giữa, CTA phải
   =================================================== *@

<header class="iq-header" id="mainHeader">
    <nav class="navbar navbar-expand-lg" id="mainNav">
        <div class="container iq-nav-container">

            <!-- ===== LOGO ===== -->
            <a class="navbar-brand iq-logo" href="/">
                <svg width="100" height="32" viewBox="0 0 120 38" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- IQAir wordmark SVG approximation -->
                    <rect x="0" y="4" width="6" height="22" rx="1" fill="#1976D2" />
                    <rect x="0" y="4" width="6" height="6" rx="1" fill="#1976D2" />
                    <!-- Q shape -->
                    <circle cx="22" cy="15" r="10" stroke="#1976D2" stroke-width="5" fill="none" />
                    <line x1="28" y1="21" x2="34" y2="27" stroke="#1976D2" stroke-width="5" stroke-linecap="round" />
                    <!-- AIR text -->
                    <text x="42" y="23" font-family="Source Sans 3, sans-serif" font-weight="700" font-size="18" fill="#0A2744">Air</text>
                </svg>
                <span class="iq-logo-text">IQAir</span>
            </a>

            <!-- ===== HAMBURGER ===== -->
            <button class="navbar-toggler iq-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarMain"
                    aria-controls="navbarMain" aria-expanded="false">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- ===== NAV ITEMS ===== -->
            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav mx-auto iq-nav-menu">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Không khí ngoài trời
                        </a>
                        <ul class="dropdown-menu iq-dropdown">
                            <li><a class="dropdown-item" href="#">Bản đồ chất lượng không khí</a></li>
                            <li><a class="dropdown-item" href="#">Xếp hạng thành phố</a></li>
                            <li><a class="dropdown-item" href="#">Báo cáo thế giới</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Không khí trong nhà
                        </a>
                        <ul class="dropdown-menu iq-dropdown">
                            <li><a class="dropdown-item" href="#">Màn hình không khí</a></li>
                            <li><a class="dropdown-item" href="#">Máy lọc không khí</a></li>
                        </ul>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link iq-nav-active" href="#">Ứng dụng</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Sản phẩm
                        </a>
                        <ul class="dropdown-menu iq-dropdown">
                            <li><a class="dropdown-item" href="#">Màn hình AirVisual Pro</a></li>
                            <li><a class="dropdown-item" href="#">AirVisual Outdoor</a></li>
                            <li><a class="dropdown-item" href="#">Máy lọc HealthPro</a></li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Doanh nghiệp
                        </a>
                        <ul class="dropdown-menu iq-dropdown">
                            <li><a class="dropdown-item" href="#">API chất lượng không khí</a></li>
                            <li><a class="dropdown-item" href="#">Dashboard doanh nghiệp</a></li>
                        </ul>
                    </li>
                </ul>

                <!-- ===== RIGHT NAV: Language + CTA ===== -->
                <div class="iq-nav-right d-flex align-items-center gap-3">
                    <!-- Language selector -->
                    <div class="dropdown iq-lang-selector">
                        <a class="dropdown-toggle iq-lang-btn" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-globe2"></i> VI
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end iq-dropdown">
                            <li><a class="dropdown-item" href="#">English</a></li>
                            <li><a class="dropdown-item active" href="#">Tiếng Việt</a></li>
                            <li><a class="dropdown-item" href="#">中文</a></li>
                        </ul>
                    </div>
                    <!-- Download CTA -->
                    <a href="#download" class="btn iq-btn-primary iq-nav-cta">
                        <i class="bi bi-download me-1"></i> Tải xuống miễn phí
                    </a>
                </div>
            </div>
        </div>
    </nav>
</header>
