@page
@model IQAirClone.Pages.AirMapModel
@{
    ViewData["Title"] = "Bản đồ không khí Việt Nam";
    Layout = "_DashboardLayout";
}

<!-- ===== TOOLBAR ===== -->
<div class="db-toolbar">
    <div class="db-toolbar-left">
        <span class="db-page-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="#1B8CDE" stroke-width="2" width="18" height="18">
                <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6" />
                <line x1="8" y1="2" x2="8" y2="18" />
                <line x1="16" y1="6" x2="16" y2="22" />
            </svg>
            Bản đồ chất lượng không khí Việt Nam
        </span>
    </div>
    <div class="db-toolbar-right">
        <!-- Legend -->
        <div class="map-legend">
            <div class="map-legend-item"><span style="background:#2DC653"></span> Tốt (0-50)</div>
            <div class="map-legend-item"><span style="background:#F5A623"></span> Trung bình (51-100)</div>
            <div class="map-legend-item"><span style="background:#E8622A"></span> Kém (101-150)</div>
            <div class="map-legend-item"><span style="background:#D93B3B"></span> Có hại (151+)</div>
        </div>
        <button class="db-tb-btn" id="mapRefreshBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                <polyline points="1 4 1 10 7 10" />
                <path d="M3.51 15a9 9 0 102.13-9.36L1 10" />
            </svg>
            Làm mới
        </button>
    </div>
</div>

<!-- ===== MAIN MAP LAYOUT ===== -->
<div class="map-container">

    <!-- LEFT: Vietnam SVG Map -->
    <div class="map-left">
        <div class="map-svg-wrapper">
            <div class="map-title-bar">
                <span class="map-updated">Cập nhật: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")</span>
                <span class="map-source">Nguồn: IQAir Vietnam</span>
            </div>

            <!-- SVG bản đồ Việt Nam dạng đơn giản với các vùng -->
            <svg id="vnMap" viewBox="0 0 300 700" xmlns="http://www.w3.org/2000/svg"
                 class="vn-map-svg">

                <!-- Miền Bắc -->
                <g class="map-region" data-region="north">
                    <!-- Hà Giang -->
                    <ellipse cx="130" cy="55" rx="22" ry="18" class="map-province"
                             data-city="Hà Giang" data-aqi="48" data-province="Hà Giang"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="130" y="59" class="map-label">48</text>

                    <!-- Lào Cai -->
                    <ellipse cx="95" cy="75" rx="20" ry="16" class="map-province"
                             data-city="Lào Cai" data-aqi="52" data-province="Lào Cai"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="95" y="79" class="map-label">52</text>

                    <!-- Điện Biên -->
                    <ellipse cx="62" cy="100" rx="22" ry="18" class="map-province"
                             data-city="Điện Biên" data-aqi="38" data-province="Điện Biên"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="62" y="104" class="map-label">38</text>

                    <!-- Thái Nguyên -->
                    <ellipse cx="165" cy="80" rx="20" ry="16" class="map-province"
                             data-city="Thái Nguyên" data-aqi="76" data-province="Thái Nguyên"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="165" y="84" class="map-label">76</text>

                    <!-- Quảng Ninh -->
                    <ellipse cx="210" cy="95" rx="22" ry="16" class="map-province"
                             data-city="Quảng Ninh" data-aqi="95" data-province="Quảng Ninh"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="210" y="99" class="map-label">95</text>

                    <!-- Hà Nội (lớn hơn vì thủ đô) -->
                    <ellipse cx="168" cy="118" rx="26" ry="20" class="map-province map-capital"
                             data-city="Hà Nội" data-aqi="87" data-province="Hà Nội"
                             fill="#F5A623" stroke="white" stroke-width="2" />
                    <text x="168" y="115" class="map-label map-label-bold">HN</text>
                    <text x="168" y="127" class="map-label">87</text>

                    <!-- Hải Phòng -->
                    <ellipse cx="210" cy="125" rx="20" ry="15" class="map-province"
                             data-city="Hải Phòng" data-aqi="67" data-province="Hải Phòng"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="210" y="129" class="map-label">67</text>

                    <!-- Nam Định -->
                    <ellipse cx="185" cy="150" rx="19" ry="14" class="map-province"
                             data-city="Nam Định" data-aqi="52" data-province="Nam Định"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="185" y="154" class="map-label">52</text>

                    <!-- Sơn La -->
                    <ellipse cx="95" cy="130" rx="22" ry="17" class="map-province"
                             data-city="Sơn La" data-aqi="41" data-province="Sơn La"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="95" y="134" class="map-label">41</text>

                    <!-- Nhãn miền -->
                    <text x="30" y="50" class="map-region-label">MIỀN BẮC</text>
                </g>

                <!-- Miền Trung -->
                <g class="map-region" data-region="central">
                    <!-- Thanh Hóa -->
                    <ellipse cx="155" cy="190" rx="24" ry="17" class="map-province"
                             data-city="Thanh Hóa" data-aqi="58" data-province="Thanh Hóa"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="155" y="194" class="map-label">58</text>

                    <!-- Nghệ An / Vinh -->
                    <ellipse cx="145" cy="228" rx="24" ry="17" class="map-province"
                             data-city="Vinh" data-aqi="63" data-province="Nghệ An"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="145" y="232" class="map-label">63</text>

                    <!-- Huế -->
                    <ellipse cx="168" cy="268" rx="21" ry="15" class="map-province"
                             data-city="Huế" data-aqi="48" data-province="Thừa Thiên Huế"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="168" y="272" class="map-label">48</text>

                    <!-- Đà Nẵng -->
                    <ellipse cx="185" cy="300" rx="22" ry="16" class="map-province map-highlight"
                             data-city="Đà Nẵng" data-aqi="42" data-province="Đà Nẵng"
                             fill="#2DC653" stroke="white" stroke-width="2" />
                    <text x="185" y="304" class="map-label">42</text>

                    <!-- Quảng Nam -->
                    <ellipse cx="175" cy="330" rx="21" ry="15" class="map-province"
                             data-city="Quảng Nam" data-aqi="44" data-province="Quảng Nam"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="175" y="334" class="map-label">44</text>

                    <!-- Quảng Ngãi -->
                    <ellipse cx="190" cy="358" rx="20" ry="14" class="map-province"
                             data-city="Quảng Ngãi" data-aqi="51" data-province="Quảng Ngãi"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="190" y="362" class="map-label">51</text>

                    <!-- Bình Định -->
                    <ellipse cx="198" cy="385" rx="20" ry="14" class="map-province"
                             data-city="Bình Định" data-aqi="55" data-province="Bình Định"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="198" y="389" class="map-label">55</text>

                    <!-- Đà Lạt / Lâm Đồng -->
                    <ellipse cx="155" cy="420" rx="22" ry="16" class="map-province"
                             data-city="Đà Lạt" data-aqi="28" data-province="Lâm Đồng"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="155" y="424" class="map-label">28</text>

                    <text x="30" y="210" class="map-region-label">MIỀN TRUNG</text>
                </g>

                <!-- Miền Nam -->
                <g class="map-region" data-region="south">
                    <!-- Bình Dương -->
                    <ellipse cx="175" cy="480" rx="20" ry="14" class="map-province"
                             data-city="Bình Dương" data-aqi="88" data-province="Bình Dương"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="175" y="484" class="map-label">88</text>

                    <!-- Đồng Nai / Biên Hòa -->
                    <ellipse cx="210" cy="488" rx="22" ry="15" class="map-province"
                             data-city="Biên Hòa" data-aqi="99" data-province="Đồng Nai"
                             fill="#F5A623" stroke="white" stroke-width="1.5" />
                    <text x="210" y="492" class="map-label">99</text>

                    <!-- TP. HCM (lớn) -->
                    <ellipse cx="180" cy="515" rx="28" ry="22" class="map-province map-capital"
                             data-city="TP. Hồ Chí Minh" data-aqi="112" data-province="TP. Hồ Chí Minh"
                             fill="#E8622A" stroke="white" stroke-width="2" />
                    <text x="180" y="511" class="map-label map-label-bold">HCM</text>
                    <text x="180" y="523" class="map-label">112</text>

                    <!-- Cần Thơ -->
                    <ellipse cx="155" cy="565" rx="22" ry="15" class="map-province"
                             data-city="Cần Thơ" data-aqi="44" data-province="Cần Thơ"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="155" y="569" class="map-label">44</text>

                    <!-- An Giang -->
                    <ellipse cx="118" cy="560" rx="20" ry="14" class="map-province"
                             data-city="An Giang" data-aqi="39" data-province="An Giang"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="118" y="564" class="map-label">39</text>

                    <!-- Kiên Giang -->
                    <ellipse cx="95" cy="595" rx="22" ry="15" class="map-province"
                             data-city="Kiên Giang" data-aqi="35" data-province="Kiên Giang"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="95" y="599" class="map-label">35</text>

                    <!-- Cà Mau -->
                    <ellipse cx="140" cy="630" rx="20" ry="14" class="map-province"
                             data-city="Cà Mau" data-aqi="31" data-province="Cà Mau"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="140" y="634" class="map-label">31</text>

                    <!-- Vũng Tàu -->
                    <ellipse cx="230" cy="530" rx="18" ry="13" class="map-province"
                             data-city="Vũng Tàu" data-aqi="46" data-province="Bà Rịa - Vũng Tàu"
                             fill="#2DC653" stroke="white" stroke-width="1.5" />
                    <text x="230" y="534" class="map-label">46</text>

                    <text x="30" y="475" class="map-region-label">MIỀN NAM</text>
                </g>

                <!-- Đường biên giới Việt Nam (đơn giản hóa) -->
                <path d="M 140 30 L 180 40 L 230 70 L 245 110 L 235 160 L 220 200
                         L 215 260 L 225 310 L 240 360 L 245 410 L 240 460
                         L 250 510 L 245 560 L 220 600 L 180 640 L 150 660
                         L 110 640 L 80 610 L 65 570 L 70 520 L 90 480
                         L 85 440 L 95 390 L 110 340 L 100 280 L 90 220
                         L 80 170 L 60 130 L 55 85 L 80 55 L 110 40 L 140 30 Z"
                      fill="none" stroke="rgba(27,140,222,0.3)" stroke-width="1.5"
                      stroke-dasharray="4,3" />

                <!-- Biển Đông label -->
                <text x="255" y="300" class="map-sea-label" transform="rotate(90,255,300)">BIỂN ĐÔNG</text>
            </svg>

            <!-- Tooltip -->
            <div class="map-tooltip" id="mapTooltip">
                <div class="map-tt-city" id="ttCity">—</div>
                <div class="map-tt-province" id="ttProvince">—</div>
                <div class="map-tt-aqi" id="ttAqi">—</div>
                <div class="map-tt-status" id="ttStatus">—</div>
            </div>
        </div>
    </div>

    <!-- RIGHT: Detail Panel -->
    <div class="map-right">
        <!-- Selected city detail -->
        <div class="map-detail-card" id="mapDetailCard">
            <div class="map-detail-header">
                <div>
                    <div class="map-detail-city" id="detailCity">Chọn một tỉnh/thành</div>
                    <div class="map-detail-province" id="detailProvince">trên bản đồ để xem chi tiết</div>
                </div>
                <div class="map-detail-gauge" id="detailGauge">
                    <canvas id="detailGaugeCanvas" width="80" height="80"></canvas>
                    <div class="map-detail-gauge-label">
                        <div class="map-detail-aqi" id="detailAqiNum">—</div>
                        <div class="map-detail-unit">AQI</div>
                    </div>
                </div>
            </div>
            <div class="map-detail-status-bar" id="detailStatusBar">
                <span id="detailStatusEmoji">🗺️</span>
                <span id="detailStatusText">Chưa chọn địa điểm</span>
            </div>
            <!-- Pollutants -->
            <div class="map-detail-polls" id="detailPolls">
                @foreach (var loc in Model.Locations)
                {
                    <div class="map-dp-item" data-city="@loc.CityName" style="display:none">
                        <div class="map-dp-row">
                            <div class="map-dp-cell"><div class="map-dp-name">PM2.5</div><div class="map-dp-val">@loc.Pm25.ToString("F1")</div><div class="map-dp-unit">µg/m³</div></div>
                            <div class="map-dp-cell"><div class="map-dp-name">PM10</div><div class="map-dp-val">@loc.Pm10.ToString("F1")</div><div class="map-dp-unit">µg/m³</div></div>
                            <div class="map-dp-cell"><div class="map-dp-name">NO2</div><div class="map-dp-val">@loc.No2.ToString("F1")</div><div class="map-dp-unit">µg/m³</div></div>
                            <div class="map-dp-cell"><div class="map-dp-name">O3</div><div class="map-dp-val">@loc.O3.ToString("F1")</div><div class="map-dp-unit">µg/m³</div></div>
                        </div>
                    </div>
                }
                <div id="detailPollsDefault" class="map-dp-placeholder">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#8BAAB8" stroke-width="1.5" width="32" height="32">
                        <circle cx="12" cy="12" r="10" />
                        <line x1="12" y1="8" x2="12" y2="12" />
                        <line x1="12" y1="16" x2="12.01" y2="16" />
                    </svg>
                    <p>Click vào một tỉnh/thành trên bản đồ</p>
                </div>
            </div>
        </div>

        <!-- Rankings list -->
        <div class="map-rank-card">
            <div class="map-rank-header">
                <span class="map-rank-title">🏆 Xếp hạng AQI hôm nay</span>
                <span class="map-rank-sub">Từ tốt → kém</span>
            </div>
            <div class="map-rank-list">
                @{
                    int rank = 1;
                }
                @foreach (var loc in Model.Locations.OrderBy(l => l.Aqi))
                {
                    <div class="map-rank-item">
                        <span class="map-rank-num @(rank <= 3 ? "top3" : "")">@rank</span>
                        <span class="map-rank-flag">🇻🇳</span>
                        <div class="map-rank-info">
                            <span class="map-rank-city">@loc.CityName</span>
                            <span class="map-rank-prov">@loc.Province</span>
                        </div>
                        <span class="map-rank-aqi-badge" style="background:@loc.Color;color:@(loc.Aqi > 100 ? "#fff" : "#1a2e3f")">
                            @loc.Aqi
                        </span>
                        <span class="map-rank-status @loc.StatusClass">@loc.StatusEmoji</span>
                    </div>
                    rank++;
                }
            </div>
        </div>
    </div>
</div>

<partial name="_Quickbar" />

@section Scripts {
    <script src="~/js/airmap.js"></script>
    <script>window.MAP_DATA = @Html.Raw(Model.LocationsJson);</script>
}
