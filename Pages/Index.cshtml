@page
@model IndexModel
@{
    ViewData["Title"] = "Ứng dụng chất lượng không khí AirVisual";
}

@* ===================================================
   Index.cshtml — IQAir Air Quality App Page
   Sections: Hero → Stats → Features → AQI Chart
             → App Showcase → Pollutants → Partners → Download CTA
   =================================================== *@


<!-- ========================================
     SECTION 1: HERO
     Background xanh đậm, mockup phone, CTA
     ======================================== -->
<section class="iq-hero" id="hero">
    <div class="iq-hero-bg-shapes">
        <div class="iq-shape iq-shape-1"></div>
        <div class="iq-shape iq-shape-2"></div>
        <div class="iq-shape iq-shape-3"></div>
    </div>
    <div class="container">
        <div class="row align-items-center iq-hero-row">

            <!-- Left: Text -->
            <div class="col-lg-6 iq-hero-content" data-animate="fadeInLeft">
                <div class="iq-hero-badge mb-3">
                    <i class="bi bi-award-fill me-2"></i> Ứng dụng chất lượng không khí #1 thế giới
                </div>
                <h1 class="iq-hero-title">
                    Theo dõi không khí<br />
                    <span class="iq-hero-highlight">thông minh hơn</span><br />
                    mỗi ngày
                </h1>
                <p class="iq-hero-desc">
                    Dữ liệu chất lượng không khí theo thời gian thực từ hơn
                    <strong>500.000+ địa điểm</strong> tại 100+ quốc gia. Dự báo 7 ngày,
                    cảnh báo ô nhiễm và lời khuyên sức khỏe tức thì.
                </p>

                <!-- App Store Buttons -->
                <div class="iq-hero-cta d-flex flex-wrap gap-3 mb-4">
                    <a href="#" class="iq-store-btn iq-store-apple">
                        <i class="bi bi-apple iq-store-icon"></i>
                        <div class="iq-store-text">
                            <small>Tải về trên</small>
                            <strong>App Store</strong>
                        </div>
                    </a>
                    <a href="#" class="iq-store-btn iq-store-google">
                        <svg class="iq-store-icon" width="24" height="24" viewBox="0 0 24 24" fill="none">
                            <path d="M3.18 23.76c.3.17.64.24.98.21l12.67-11.63-2.98-2.98L3.18 23.76z" fill="#EA4335" />
                            <path d="M22.45 10.56l-2.97-1.7-3.37 3.08 3.37 3.09 2.99-1.72c.85-.49.85-2.26-.02-2.75z" fill="#FBBC05" />
                            <path d="M3.18.24C2.83.21 2.49.28 2.19.45L14.52 12.7l2.99-2.98L3.18.24z" fill="#4285F4" />
                            <path d="M2.19.45C1.44.88 1 1.73 1 2.87v18.26c0 1.14.44 1.99 1.19 2.43l12.33-12.33L2.19.45z" fill="#34A853" />
                        </svg>
                        <div class="iq-store-text">
                            <small>Tải về trên</small>
                            <strong>Google Play</strong>
                        </div>
                    </a>
                </div>

                <!-- Trust indicators -->
                <div class="iq-hero-trust">
                    <div class="iq-trust-item">
                        <i class="bi bi-star-fill text-warning"></i>
                        <span>4.8/5 trên App Store</span>
                    </div>
                    <div class="iq-trust-sep"></div>
                    <div class="iq-trust-item">
                        <i class="bi bi-download text-info"></i>
                        <span>10M+ lượt tải</span>
                    </div>
                    <div class="iq-trust-sep"></div>
                    <div class="iq-trust-item">
                        <i class="bi bi-shield-check text-success"></i>
                        <span>Miễn phí hoàn toàn</span>
                    </div>
                </div>
            </div>

            <!-- Right: Phone Mockup -->
            <div class="col-lg-6 iq-hero-mockup-col" data-animate="fadeInRight">
                <div class="iq-phone-wrapper">
                    <div class="iq-phone-mockup">
                        <!-- Phone frame -->
                        <div class="iq-phone-screen">
                            <!-- App UI simulation inside phone -->
                            <div class="iq-app-screen">
                                <div class="iq-app-header-bar">
                                    <span class="iq-app-location"><i class="bi bi-geo-alt-fill"></i> Đà Nẵng, Việt Nam</span>
                                    <i class="bi bi-bell"></i>
                                </div>
                                <div class="iq-app-aqi-main">
                                    <div class="iq-app-aqi-circle" id="heroAqiCircle">
                                        <div class="iq-aqi-number">42</div>
                                        <div class="iq-aqi-label">AQI US</div>
                                    </div>
                                    <div class="iq-app-aqi-status good">Tốt</div>
                                    <p class="iq-app-aqi-msg">Không khí trong lành. Lý tưởng cho hoạt động ngoài trời!</p>
                                </div>
                                <div class="iq-app-pollutants-row">
                                    <div class="iq-app-poll-item">
                                        <small>PM2.5</small>
                                        <span>8.2</span>
                                    </div>
                                    <div class="iq-app-poll-item">
                                        <small>PM10</small>
                                        <span>14.1</span>
                                    </div>
                                    <div class="iq-app-poll-item">
                                        <small>O₃</small>
                                        <span>31.4</span>
                                    </div>
                                    <div class="iq-app-poll-item">
                                        <small>NO₂</small>
                                        <span>12.7</span>
                                    </div>
                                </div>
                                <div class="iq-app-forecast">
                                    <div class="iq-app-forecast-title">Dự báo 24h</div>
                                    <canvas id="miniChart" width="240" height="60"></canvas>
                                </div>
                            </div>
                        </div>
                        <!-- Phone notch -->
                        <div class="iq-phone-notch"></div>
                    </div>
                    <!-- Floating cards around phone -->
                    <div class="iq-float-card iq-float-card-1" data-animate="floatIn">
                        <i class="bi bi-wind text-info"></i>
                        <div>
                            <small>Gió</small>
                            <strong>12 km/h</strong>
                        </div>
                    </div>
                    <div class="iq-float-card iq-float-card-2" data-animate="floatIn">
                        <i class="bi bi-thermometer-half text-warning"></i>
                        <div>
                            <small>Nhiệt độ</small>
                            <strong>28°C</strong>
                        </div>
                    </div>
                    <div class="iq-float-card iq-float-card-3" data-animate="floatIn">
                        <i class="bi bi-droplet-fill text-primary"></i>
                        <div>
                            <small>Độ ẩm</small>
                            <strong>72%</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================
     SECTION 2: STATS BAR
     3 con số nổi bật
     ======================================== -->
<section class="iq-stats-bar">
    <div class="container">
        <div class="row">
            <div class="col-md-4 iq-stat-item" data-animate="countUp">
                <div class="iq-stat-number" data-target="500000">0</div>
                <div class="iq-stat-plus">+</div>
                <div class="iq-stat-label">Địa điểm được theo dõi</div>
            </div>
            <div class="col-md-4 iq-stat-item iq-stat-border" data-animate="countUp">
                <div class="iq-stat-number" data-target="100">0</div>
                <div class="iq-stat-plus">+</div>
                <div class="iq-stat-label">Quốc gia và vùng lãnh thổ</div>
            </div>
            <div class="col-md-4 iq-stat-item" data-animate="countUp">
                <div class="iq-stat-number" data-target="10">0</div>
                <div class="iq-stat-plus">M+</div>
                <div class="iq-stat-label">Người dùng tin tưởng</div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================
     SECTION 3: FEATURES GRID
     6 tính năng chính
     ======================================== -->
<section class="iq-features" id="features">
    <div class="container">
        <div class="iq-section-header text-center" data-animate="fadeInUp">
            <div class="iq-section-badge">Tính năng nổi bật</div>
            <h2 class="iq-section-title">Mọi thứ bạn cần để<br />bảo vệ sức khỏe</h2>
            <p class="iq-section-subtitle">
                Ứng dụng AirVisual cung cấp đầy đủ dữ liệu và công cụ giúp bạn
                đưa ra quyết định thông minh về chất lượng không khí xung quanh.
            </p>
        </div>

        <div class="row g-4 iq-features-grid">

            <!-- Feature 1 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="0">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-blue">
                        <i class="bi bi-geo-alt-fill"></i>
                    </div>
                    <h4 class="iq-feature-title">Dữ liệu thời gian thực</h4>
                    <p class="iq-feature-desc">
                        Theo dõi chỉ số AQI, PM2.5, PM10, Ozone, NO₂, CO và SO₂
                        cập nhật liên tục từ hàng nghìn trạm quan trắc chính phủ
                        và cảm biến IQAir được xác thực.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <!-- Feature 2 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="100">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-green">
                        <i class="bi bi-graph-up-arrow"></i>
                    </div>
                    <h4 class="iq-feature-title">Dự báo 7 ngày AI</h4>
                    <p class="iq-feature-desc">
                        Mô hình dự báo được phát triển bằng Machine Learning và AI
                        cung cấp dự báo chính xác lên đến 7 ngày, giúp bạn lên kế
                        hoạch hoạt động ngoài trời hợp lý.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <!-- Feature 3 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="200">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-orange">
                        <i class="bi bi-bell-fill"></i>
                    </div>
                    <h4 class="iq-feature-title">Cảnh báo thông minh</h4>
                    <p class="iq-feature-desc">
                        Nhận thông báo tức thì khi chất lượng không khí thay đổi.
                        Tùy chỉnh ngưỡng cảnh báo phù hợp với tình trạng sức khỏe
                        của bạn và gia đình.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <!-- Feature 4 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="0">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-purple">
                        <i class="bi bi-map-fill"></i>
                    </div>
                    <h4 class="iq-feature-title">Bản đồ ô nhiễm toàn cầu</h4>
                    <p class="iq-feature-desc">
                        Xem bản đồ ô nhiễm không khí toàn cầu theo thời gian thực.
                        Bao gồm dữ liệu vệ tinh, trạm quan trắc mặt đất và
                        cảm biến cộng đồng.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <!-- Feature 5 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="100">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-teal">
                        <i class="bi bi-house-fill"></i>
                    </div>
                    <h4 class="iq-feature-title">Theo dõi trong nhà</h4>
                    <p class="iq-feature-desc">
                        Kết nối với màn hình AirVisual Pro để theo dõi PM2.5,
                        CO₂, nhiệt độ và độ ẩm trong nhà. Điều khiển máy lọc
                        không khí ngay từ ứng dụng.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>

            <!-- Feature 6 -->
            <div class="col-lg-4 col-md-6" data-animate="fadeInUp" data-delay="200">
                <div class="iq-feature-card">
                    <div class="iq-feature-icon iq-icon-red">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </div>
                    <h4 class="iq-feature-title">Khuyến nghị sức khỏe</h4>
                    <p class="iq-feature-desc">
                        Nhận lời khuyên sức khỏe cá nhân hóa theo tình trạng của bạn
                        (hen suyễn, dị ứng, tim mạch). Biết khi nào nên đeo khẩu trang
                        và khi nào an toàn để ra ngoài.
                    </p>
                    <a href="#" class="iq-feature-link">Tìm hiểu thêm <i class="bi bi-arrow-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================
     SECTION 4: AQI CHART
     Biểu đồ Chart.js + bảng giải thích AQI
     ======================================== -->
<section class="iq-aqi-section" id="aqi">
    <div class="container">
        <div class="row align-items-center g-5">

            <!-- Left: Chart -->
            <div class="col-lg-7" data-animate="fadeInLeft">
                <div class="iq-chart-wrapper">
                    <div class="iq-chart-header">
                        <h3 class="iq-chart-title">Chỉ số AQI — Đà Nẵng, 7 ngày qua</h3>
                        <div class="iq-chart-tabs">
                            <button class="iq-chart-tab active" data-period="7d">7 ngày</button>
                            <button class="iq-chart-tab" data-period="30d">30 ngày</button>
                            <button class="iq-chart-tab" data-period="1y">1 năm</button>
                        </div>
                    </div>
                    <canvas id="aqiChart" height="280"></canvas>
                </div>
            </div>

            <!-- Right: AQI Table -->
            <div class="col-lg-5" data-animate="fadeInRight">
                <div class="iq-section-badge mb-3">Hiểu về AQI</div>
                <h2 class="iq-section-title mb-4">Chỉ số chất lượng<br />không khí là gì?</h2>
                <p class="iq-section-desc mb-4">
                    AQI (Air Quality Index) là thang đo tiêu chuẩn của EPA Hoa Kỳ,
                    cho biết mức độ ô nhiễm không khí và tác động đến sức khỏe.
                </p>

                <!-- AQI Legend Table -->
                <div class="iq-aqi-table">
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#00E400;"></div>
                        <div class="iq-aqi-range">0–50</div>
                        <div class="iq-aqi-status-text">Tốt</div>
                        <div class="iq-aqi-desc-text">Không khí trong lành</div>
                    </div>
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#FFFF00;"></div>
                        <div class="iq-aqi-range">51–100</div>
                        <div class="iq-aqi-status-text">Trung bình</div>
                        <div class="iq-aqi-desc-text">Chấp nhận được</div>
                    </div>
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#FF7E00;"></div>
                        <div class="iq-aqi-range">101–150</div>
                        <div class="iq-aqi-status-text">Không tốt cho nhóm nhạy cảm</div>
                        <div class="iq-aqi-desc-text">Trẻ em, người già nên hạn chế</div>
                    </div>
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#FF0000;"></div>
                        <div class="iq-aqi-range">151–200</div>
                        <div class="iq-aqi-status-text">Có hại</div>
                        <div class="iq-aqi-desc-text">Mọi người nên hạn chế ra ngoài</div>
                    </div>
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#8F3F97;"></div>
                        <div class="iq-aqi-range">201–300</div>
                        <div class="iq-aqi-status-text">Rất có hại</div>
                        <div class="iq-aqi-desc-text">Tránh mọi hoạt động ngoài trời</div>
                    </div>
                    <div class="iq-aqi-row">
                        <div class="iq-aqi-color" style="background:#7E0023;"></div>
                        <div class="iq-aqi-range">301+</div>
                        <div class="iq-aqi-status-text">Nguy hiểm</div>
                        <div class="iq-aqi-desc-text">Tình trạng khẩn cấp về sức khỏe</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================
     SECTION 5: APP SHOWCASE (Phone Screenshots)
     ======================================== -->
<section class="iq-showcase" id="showcase">
    <div class="container">
        <div class="iq-section-header text-center mb-5" data-animate="fadeInUp">
            <div class="iq-section-badge">Giao diện ứng dụng</div>
            <h2 class="iq-section-title">Đẹp, trực quan<br />và dễ sử dụng</h2>
        </div>

        <div class="iq-showcase-phones" data-animate="fadeInUp">
            <!-- Phone 1: Map Screen -->
            <div class="iq-showcase-phone iq-sp-side">
                <div class="iq-sp-frame">
                    <div class="iq-sp-screen iq-sp-map">
                        <div class="iq-sp-screen-header">Bản đồ thế giới</div>
                        <div class="iq-sp-map-dots">
                            <div class="iq-map-dot" style="top:30%;left:40%;background:#00E400;" title="Tốt"></div>
                            <div class="iq-map-dot" style="top:45%;left:55%;background:#FFFF00;" title="TB"></div>
                            <div class="iq-map-dot" style="top:35%;left:70%;background:#FF7E00;" title="Xấu"></div>
                            <div class="iq-map-dot" style="top:60%;left:35%;background:#00E400;" title="Tốt"></div>
                            <div class="iq-map-dot" style="top:55%;left:65%;background:#FF0000;" title="Có hại"></div>
                        </div>
                        <div class="iq-sp-legend">
                            <span style="background:#00E400"></span> Tốt
                            <span style="background:#FF7E00"></span> Trung bình
                            <span style="background:#FF0000"></span> Có hại
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phone 2: Main Screen (center/featured) -->
            <div class="iq-showcase-phone iq-sp-center">
                <div class="iq-sp-frame iq-sp-frame-main">
                    <div class="iq-sp-screen iq-sp-main">
                        <div class="iq-sp-top-bar">
                            <span><i class="bi bi-geo-alt-fill"></i> Hà Nội</span>
                            <span class="iq-sp-time">08:45</span>
                        </div>
                        <div class="iq-sp-aqi-display">
                            <div class="iq-sp-aqi-num" style="color:#FFFF00;">87</div>
                            <div class="iq-sp-aqi-us">AQI US</div>
                            <div class="iq-sp-aqi-cat" style="color:#FFFF00;">Trung bình</div>
                        </div>
                        <div class="iq-sp-face">😐</div>
                        <p class="iq-sp-advice">Người nhạy cảm nên hạn chế ở ngoài lâu</p>
                        <div class="iq-sp-mini-chart">
                            <canvas id="showcaseChart" width="200" height="60"></canvas>
                        </div>
                        <div class="iq-sp-polls">
                            <div class="iq-sp-poll"><span>PM2.5</span><b>24.1</b></div>
                            <div class="iq-sp-poll"><span>O₃</span><b>41.2</b></div>
                            <div class="iq-sp-poll"><span>NO₂</span><b>18.9</b></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Phone 3: Ranking Screen -->
            <div class="iq-showcase-phone iq-sp-side">
                <div class="iq-sp-frame">
                    <div class="iq-sp-screen iq-sp-rank">
                        <div class="iq-sp-screen-header">Xếp hạng thành phố</div>
                        <div class="iq-rank-list">
                            <div class="iq-rank-item">
                                <span class="iq-rank-num">1</span>
                                <span class="iq-rank-city">Hà Nội</span>
                                <span class="iq-rank-aqi" style="background:#FFFF00;color:#333;">87</span>
                            </div>
                            <div class="iq-rank-item">
                                <span class="iq-rank-num">2</span>
                                <span class="iq-rank-city">TP.HCM</span>
                                <span class="iq-rank-aqi" style="background:#FF7E00;color:#fff;">112</span>
                            </div>
                            <div class="iq-rank-item">
                                <span class="iq-rank-num">3</span>
                                <span class="iq-rank-city">Đà Nẵng</span>
                                <span class="iq-rank-aqi" style="background:#00E400;color:#333;">42</span>
                            </div>
                            <div class="iq-rank-item">
                                <span class="iq-rank-num">4</span>
                                <span class="iq-rank-city">Cần Thơ</span>
                                <span class="iq-rank-aqi" style="background:#00E400;color:#333;">38</span>
                            </div>
                            <div class="iq-rank-item">
                                <span class="iq-rank-num">5</span>
                                <span class="iq-rank-city">Hải Phòng</span>
                                <span class="iq-rank-aqi" style="background:#FFFF00;color:#333;">67</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<!-- ========================================
     SECTION 6: POLLUTANTS
     6 chất ô nhiễm được theo dõi
     ======================================== -->
<section class="iq-pollutants" id="pollutants">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-5" data-animate="fadeInLeft">
                <div class="iq-section-badge">Chất ô nhiễm</div>
                <h2 class="iq-section-title">Theo dõi 6 chất<br />ô nhiễm chính</h2>
                <p class="iq-section-desc">
                    IQAir AirVisual theo dõi đầy đủ 6 chất ô nhiễm theo tiêu chuẩn
                    EPA Hoa Kỳ — cho bạn bức tranh toàn diện về chất lượng không khí
                    đang thở mỗi ngày.
