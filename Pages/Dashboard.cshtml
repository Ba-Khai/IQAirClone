        <rect x="175" y="0" width="10" height="10" />
        <rect x="220" y="45" width="40" height="35" />
        <rect x="270" y="30" width="55" height="50" />
        <rect x="285" y="20" width="25" height="10" />
        <rect x="335" y="50" width="35" height="30" />
        <rect x="380" y="25" width="65" height="55" />
        <rect x="395" y="15" width="35" height="10" />
        <rect x="455" y="40" width="45" height="40" />
        <rect x="510" y="15" width="70" height="65" />
        <rect x="530" y="5" width="30" height="10" />
        <rect x="542" y="0" width="6" height="5" />
        <rect x="590" y="35" width="50" height="45" />
        <rect x="650" y="20" width="60" height="60" />
        <rect x="665" y="10" width="30" height="10" />
        <rect x="720" y="45" width="40" height="35" />
        <rect x="770" y="30" width="55" height="50" />
        <rect x="835" y="50" width="30" height="30" />
        <rect x="875" y="20" width="65" height="60" />
        <rect x="890" y="10" width="35" height="10" />
        <rect x="950" y="40" width="45" height="40" />
        <rect x="1005" y="15" width="70" height="65" />
