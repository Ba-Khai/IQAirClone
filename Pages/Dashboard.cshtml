@page
@model IQAirClone.Pages.DashboardModel
@{
    ViewData["Title"] = "Dashboard - Chất lượng không khí Việt Nam";
    Layout = "_DashboardLayout";
}

@* =====================================================
   Dashboard.cshtml
   File này nằm trong Pages/ của project IQAirClone
   Layout riêng (_DashboardLayout) để không đụng Index
   ===================================================== *@

<!-- ===== HERO ===== -->
