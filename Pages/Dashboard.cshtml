</div>

<!-- ===== TOOLBAR ===== -->
<div class="db-toolbar">
    <div class="db-toolbar-left">
        <button class="db-watchlist-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="#1B8CDE" stroke-width="2" width="15" height="15">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            Danh sách theo dõi
            <span class="db-watchlist-count">@Model.Locations.Count</span>
        </button>
    </div>
    <div class="db-toolbar-right">
        <button class="db-tb-btn" id="dbFilterBtn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                <line x1="21" y1="4" x2="14" y2="4" />
                <line x1="10" y1="4" x2="3" y2="4" />
                <line x1="21" y1="12" x2="12" y2="12" />
                <line x1="8" y1="12" x2="3" y2="12" />
                <line x1="21" y1="20" x2="16" y2="20" />
                <line x1="12" y1="20" x2="3" y2="20" />
                <line x1="14" y1="2" x2="14" y2="6" />
                <line x1="8" y1="10" x2="8" y2="14" />
                <line x1="16" y1="18" x2="16" y2="22" />
            </svg>
            Sắp xếp & Lọc
        </button>
        <button class="db-tb-btn db-tb-manage">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13">
                <path d="M12 20h9" />
                <path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
            Quản lý
        </button>
    </div>
</div>

<!-- ===== CARDS GRID ===== -->
<div class="db-cards-area">
    <div class="db-cards-grid" id="dbCardsGrid">
        @for (int i = 0; i < Model.Locations.Count; i++)
        {
            var loc = Model.Locations[i];
            <div class="db-card" style="animation-delay:@(i * 60)ms"
                 data-index="@i" data-aqi="@loc.Aqi" data-color="@loc.Color">

                <!-- Dòng trạng thái -->
                <div class="db-card-status">
                    <div class="db-status-dot" style="background:@loc.Color"></div>
                    <span class="@loc.StatusClass" style="font-weight:700">
                        @loc.StatusEmoji @loc.StatusText
                    </span>
                </div>

                <!-- Tên thành phố + Gauge -->
                <div class="db-card-top">
                    <div>
                        <div class="db-card-city">@loc.CityName</div>
                        <div class="db-card-province">
                            <span>@loc.Flag</span> @loc.Province
                        </div>
                    </div>
                    <div class="db-gauge">
                        <canvas id="dbGauge_@i" width="68" height="68"></canvas>
                        <div class="db-gauge-label">
                            <div class="db-gauge-num" style="color:@loc.Color">@loc.Aqi</div>
                            <div class="db-gauge-unit">AQI</div>
                        </div>
                    </div>
                </div>

                <!-- 4 chỉ số ô nhiễm -->
                <div class="db-polls">
                    <div class="db-poll">
                        <div class="db-poll-name">PM2.5</div>
                        <div class="db-poll-val">@loc.Pm25.ToString("F2")</div>
                        <div class="db-poll-unit">µg/m³</div>
                    </div>
                    <div class="db-poll">
                        <div class="db-poll-name">PM10</div>
                        <div class="db-poll-val">@loc.Pm10.ToString("F1")</div>
                        <div class="db-poll-unit">µg/m³</div>
                    </div>
                    <div class="db-poll">
                        <div class="db-poll-name">NO2</div>
                        <div class="db-poll-val">@loc.No2.ToString("F2")</div>
                        <div class="db-poll-unit">µg/m³</div>
                    </div>
                    <div class="db-poll">
                        <div class="db-poll-name">O3</div>
                        <div class="db-poll-val">@loc.O3.ToString("F1")</div>
                        <div class="db-poll-unit">µg/m³</div>
                    </div>
                </div>

                <div class="db-card-hr"></div>

                <!-- Mini forecast chart -->
                <div class="db-chart-label">Dự báo chất lượng không khí</div>
                <div class="db-chart-wrap">
                    <canvas id="dbChart_@i"></canvas>
                </div>
            </div>
        }
    </div>
</div>

<!-- ===== FILTER PANEL ===== -->
<div class="db-filter-overlay" id="dbFilterOverlay">
    <div class="db-filter-panel">
        <div class="db-filter-tabs">
            <button class="db-filter-tab active">Lọc</button>
            <button class="db-filter-tab">Sắp xếp</button>
        </div>
        <div class="db-filter-body">
            <div class="db-filter-title">Chỉ số AQI</div>
            <div class="db-slider-labels">
                <span>0</span><span style="margin-left:auto">300+</span>
            </div>
            <div class="db-aqi-emojis">
                <div class="db-emoji-item"><span>😊</span>Tốt</div>
                <div class="db-emoji-item"><span>🙂</span>Khá</div>
                <div class="db-emoji-item"><span>😐</span>Trung bình</div>
                <div class="db-emoji-item"><span>😷</span>Kém</div>
                <div class="db-emoji-item"><span>🤢</span>Nguy hiểm</div>
            </div>
            <div class="db-aqi-rainbow"></div>
            <input type="range" class="db-range" min="0" max="300" value="150" id="dbRange" />

            <div class="db-filter-title" style="margin-top:16px">Khu vực</div>
            <div class="db-chips">
                <div class="db-chip active">🏙️ Miền Bắc</div>
                <div class="db-chip active">☀️ Miền Trung</div>
                <div class="db-chip active">🌴 Miền Nam</div>
                <div class="db-chip">🏔️ Tây Nguyên</div>
                <div class="db-chip">🏝️ Ven biển</div>
            </div>
        </div>
        <div class="db-filter-footer">
            <button class="db-filter-reset">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" width="12" height="12">
                    <polyline points="1 4 1 10 7 10" />
                    <path d="M3.51 15a9 9 0 102.13-9.36L1 10" />
                </svg>
                Đặt lại
            </button>
            <div style="display:flex;gap:8px">
                <button class="db-btn-cancel" id="dbFilterClose">Hủy</button>
                <button class="db-btn-apply" id="dbFilterApply">Áp dụng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        window.DB_LOCATIONS = @Html.Raw(Model.LocationsJson);
    </script>
}
